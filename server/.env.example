PORT=3000
PUBLIC_API_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:5173

CLOCK_TIMEZONE=America/New_York
CLOCK_FORMAT=12h
IMAGE_SIZE=1024
GENERATION_INTERVAL_MINUTES=5
GENERATION_JITTER_MINUTES=4
RETENTION_HOURS=24
MEDIA_ROOT=./data

MIN_REFRESH_INTERVAL_MINUTES=5
MAX_REFRESH_INTERVAL_MINUTES=60
DEFAULT_REFRESH_INTERVAL_MINUTES=5
REFRESH_INTERVAL_STEP_MINUTES=5
DEFAULT_HISTORY_LIMIT=1440
MAX_HISTORY_LIMIT=1440

RENDER_MODE=fal
ALLOW_MOCK_FALLBACK=true

FAL_KEY=
FAL_MODEL=fal-ai/illusion-diffusion
FAL_GUIDANCE_SCALE=5.5
FAL_CONTROLNET_CONDITIONING_SCALE=1
FAL_CONTROL_GUIDANCE_START=0
FAL_CONTROL_GUIDANCE_END=1
FAL_NUM_INFERENCE_STEPS=40
FAL_SCHEDULER=Euler

COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW_PATH=./workflows/illusion-diffusion.api.json
COMFYUI_TIMEOUT_MS=180000
COMFYUI_POLL_INTERVAL_MS=1500

PROMPT_PRESETS=
NEGATIVE_PROMPT=visible text, watermark, signature, logo, low resolution, blurry details, cropped subject, extra limbs, deformed anatomy, clock face, obvious digits, subtitles
